{
  "name": "webrtc-screen-mirroring",
  "version": "1.0.0",
  "description": "WebRTC-based screen mirroring system for educational presentations",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:prod": "node scripts/build-production.js",
