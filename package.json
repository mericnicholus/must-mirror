    "qrcode": "^1.5.3",
    "socket.io": "^4.7.2",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "javascript-obfuscator": "^5.4.1",
    "nodemon": "^3.0.1",
    "terser": "^5.46.1"
